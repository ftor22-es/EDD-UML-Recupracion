          <mxGeometry height="60" width="30" x="295" y="3502" as="geometry" />
        </mxCell>
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;%%{init: {&#39;theme&#39;: &#39;base&#39;, &#39;themeVariables&#39;: {&#39;actorBkg&#39;: &#39;#ffffff&#39;, &#39;actorBorder&#39;: &#39;#000000&#39;, &#39;actorTextColor&#39;: &#39;#000000&#39;, &#39;actorLineColor&#39;: &#39;#000000&#39;, &#39;signalColor&#39;: &#39;#000000&#39;, &#39;signalTextColor&#39;: &#39;#000000&#39;, &#39;labelBoxBkgColor&#39;: &#39;#ffffff&#39;, &#39;labelBoxBorderColor&#39;: &#39;#000000&#39;, &#39;labelTextColor&#39;: &#39;#000000&#39;, &#39;loopTextColor&#39;: &#39;#000000&#39;, &#39;noteBorderColor&#39;: &#39;#000000&#39;, &#39;noteBkgColor&#39;: &#39;#ffffff&#39;, &#39;noteTextColor&#39;: &#39;#000000&#39;, &#39;activationBorderColor&#39;: &#39;#000000&#39;, &#39;activationBkgColor&#39;: &#39;#ffffff&#39;}}}%%\nsequenceDiagram\n    actor Usuario\n    participant F as :FormularioLogin\n    participant C as :ControlAccesos\n    participant BD as :BaseDatos\n    participant ZA as :ZonaAdmin\n    participant ZU as :ZonaUsuario\n\n    loop [max 3 intentos]\n        Usuario-&gt;&gt;F: 1. completarFormulario(userId, password)\n        Usuario-&gt;&gt;F: 2. pulsarEnviar()\n        F-&gt;&gt;F: 3. validacionLocal(userId, password)\n\n        alt [validacion local correcta]\n            F-&gt;&gt;C: 4. enviarDatos(userId, password)\n            C-&gt;&gt;BD: 5. contrastarUsuario(userId, password)\n\n            alt [usuario no existe]\n                BD--&gt;&gt;C: 6. usuarioNoEncontrado()\n                C--&gt;&gt;F: 7. mostrarError(&#39;Usuario no registrado&#39;)\n                F--&gt;&gt;Usuario: 8. mostrarError(&#39;Usuario no registrado&#39;)\n            else [usuario es admin]\n                BD--&gt;&gt;C: 6. usuarioAdmin()\n                C--&gt;&gt;F: 7. accesoAdmin()\n                F-&gt;&gt;ZA: 8. redirigirZonaAdmin()\n                ZA--&gt;&gt;Usuario: 9. mostrarZonaAdmin()\n            else [usuario sin privilegios admin]\n                BD--&gt;&gt;C: 6. usuarioParticular()\n                C--&gt;&gt;F: 7. accesoUsuario()\n                F-&gt;&gt;ZU: 8. redirigirZonaUsuario()\n                ZU--&gt;&gt;Usuario: 9. mostrarZonaUsuario()\n            end\n        else [validacion local incorrecta]\n            F--&gt;&gt;Usuario: 4. mostrarError(&#39;Datos incorrectos&#39;)\n        end\n    end\n\n    F--&gt;&gt;Usuario: 10. cuentaBloqueada(&#39;Maximo de intentos alcanzado&#39;)\n&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="bpqTHxUsjjdNOZI-eCtv-96">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry height="1440" width="133" as="geometry" />
          </mxCell>
        </UserObject>
