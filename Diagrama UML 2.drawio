        </mxCell>
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;%%{init: {&#39;theme&#39;: &#39;base&#39;, &#39;themeVariables&#39;: {&#39;actorBkg&#39;: &#39;#ffffff&#39;, &#39;actorBorder&#39;: &#39;#000000&#39;, &#39;actorTextColor&#39;: &#39;#000000&#39;, &#39;actorLineColor&#39;: &#39;#000000&#39;, &#39;signalColor&#39;: &#39;#000000&#39;, &#39;signalTextColor&#39;: &#39;#000000&#39;, &#39;labelBoxBkgColor&#39;: &#39;#ffffff&#39;, &#39;labelBoxBorderColor&#39;: &#39;#000000&#39;, &#39;labelTextColor&#39;: &#39;#000000&#39;, &#39;loopTextColor&#39;: &#39;#000000&#39;, &#39;noteBorderColor&#39;: &#39;#000000&#39;, &#39;noteBkgColor&#39;: &#39;#ffffff&#39;, &#39;noteTextColor&#39;: &#39;#000000&#39;, &#39;activationBorderColor&#39;: &#39;#000000&#39;, &#39;activationBkgColor&#39;: &#39;#ffffff&#39;}}}%%\nsequenceDiagram\n    actor Usuario\n    participant A as :App Supermercado\n    participant AL as :Almacén\n    participant B as :Sistema Bancario\n    participant E as :Servicio Email\n\n    Usuario-&gt;&gt;A: 1. crearPedido()\n    A--&gt;&gt;Usuario: 2. pedidoCreado()\n\n    loop [hasta que el usuario cierre el pedido]\n        Usuario-&gt;&gt;A: 3. añadirProducto(producto)\n        A-&gt;&gt;AL: 4. comprobarStock(producto)\n        alt [hay stock]\n            AL--&gt;&gt;A: 5. stockDisponible()\n            A--&gt;&gt;Usuario: 6. productoAñadido()\n        else [no hay stock]\n            AL--&gt;&gt;A: 5. sinStock()\n            A-&gt;&gt;AL: 6. emitirPeticionAlmacen(producto)\n            A--&gt;&gt;Usuario: 7. productoNoDisponible()\n        end\n    end\n\n    Usuario-&gt;&gt;A: 8. cerrarPedido()\n    Usuario-&gt;&gt;A: 9. introducirDatosBancarios(datos)\n    A-&gt;&gt;B: 10. procesarCobro(importe, datos)\n    alt [cobro confirmado]\n        B--&gt;&gt;A: 11. cobroConfirmado()\n        A-&gt;&gt;E: 12. enviarEmail(usuario, &#39;Pedido en curso&#39;)\n        E--&gt;&gt;Usuario: 13. emailConfirmacion()\n        A--&gt;&gt;Usuario: 14. mostrarConfirmacion()\n    else [cobro denegado]\n        B--&gt;&gt;A: 11. coboDenegado()\n        A--&gt;&gt;Usuario: 12. mostrarError(&#39;Pago denegado&#39;)\n    end\n&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="bpqTHxUsjjdNOZI-eCtv-57">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry height="1282" width="105" as="geometry" />
          </mxCell>
        </UserObject>
