        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;%%{init: {&#39;theme&#39;: &#39;base&#39;, &#39;themeVariables&#39;: {&#39;actorBkg&#39;: &#39;#ffffff&#39;, &#39;actorBorder&#39;: &#39;#000000&#39;, &#39;actorTextColor&#39;: &#39;#000000&#39;, &#39;actorLineColor&#39;: &#39;#000000&#39;, &#39;signalColor&#39;: &#39;#000000&#39;, &#39;signalTextColor&#39;: &#39;#000000&#39;, &#39;labelBoxBkgColor&#39;: &#39;#ffffff&#39;, &#39;labelBoxBorderColor&#39;: &#39;#000000&#39;, &#39;labelTextColor&#39;: &#39;#000000&#39;, &#39;loopTextColor&#39;: &#39;#000000&#39;, &#39;noteBorderColor&#39;: &#39;#000000&#39;, &#39;noteBkgColor&#39;: &#39;#ffffff&#39;, &#39;noteTextColor&#39;: &#39;#000000&#39;, &#39;activationBorderColor&#39;: &#39;#000000&#39;, &#39;activationBkgColor&#39;: &#39;#ffffff&#39;}}}%%\nsequenceDiagram\n    actor Usuario\n    participant L as :Lector de Tarjetas\n    participant B as :Sistema Bancario\n    participant M as :Monitor Cajero\n\n    Usuario-&gt;&gt;L: 1. insertarTarjeta()\n    Usuario-&gt;&gt;L: 2. introducirCodigo(pin)\n    L-&gt;&gt;L: 3. comprobarBandaTarjeta()\n\n    alt [banda correcta]\n        L-&gt;&gt;B: 4. verificarCredenciales(tarjeta, pin)\n        alt [credenciales correctas]\n            B-&gt;&gt;M: 5. emitirMensajeConfirmacion()\n            M--&gt;&gt;Usuario: 6. mostrarConfirmacion()\n            Usuario-&gt;&gt;M: 7. introducirCantidad(importe)\n            M-&gt;&gt;B: 8. comprobarSaldo(importe)\n            alt [saldo suficiente]\n                B--&gt;&gt;M: 9. saldoOK()\n                M--&gt;&gt;Usuario: 10. emitirBilletes(importe)\n            else [saldo insuficiente]\n                B--&gt;&gt;M: 9. saldoInsuficiente()\n                M--&gt;&gt;Usuario: 10. mostrarError(&#39;Saldo insuficiente&#39;)\n            end\n        else [credenciales incorrectas]\n            B-&gt;&gt;M: 5. emitirMensajeDenegacion()\n            M--&gt;&gt;Usuario: 6. mostrarDenegacion()\n        end\n    else [banda incorrecta]\n        L--&gt;&gt;Usuario: 4. mostrarError(&#39;Tarjeta no valida&#39;)\n    end\n&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="bpqTHxUsjjdNOZI-eCtv-20">
