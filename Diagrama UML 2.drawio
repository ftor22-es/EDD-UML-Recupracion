        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;%%{init: {&#39;theme&#39;: &#39;base&#39;, &#39;themeVariables&#39;: {&#39;actorBkg&#39;: &#39;#ffffff&#39;, &#39;actorBorder&#39;: &#39;#000000&#39;, &#39;actorTextColor&#39;: &#39;#000000&#39;, &#39;actorLineColor&#39;: &#39;#000000&#39;, &#39;signalColor&#39;: &#39;#000000&#39;, &#39;signalTextColor&#39;: &#39;#000000&#39;, &#39;labelBoxBkgColor&#39;: &#39;#dae8fc&#39;, &#39;labelBoxBorderColor&#39;: &#39;#6c8ebf&#39;, &#39;labelTextColor&#39;: &#39;#000000&#39;, &#39;loopTextColor&#39;: &#39;#000000&#39;, &#39;noteBorderColor&#39;: &#39;#6c8ebf&#39;, &#39;noteBkgColor&#39;: &#39;#dae8fc&#39;, &#39;noteTextColor&#39;: &#39;#000000&#39;, &#39;activationBorderColor&#39;: &#39;#000000&#39;, &#39;activationBkgColor&#39;: &#39;#dae8fc&#39;, &#39;sequenceNumberColor&#39;: &#39;#000000&#39;}}}%%\nsequenceDiagram\n    actor Usuario\n    participant F as :Formulario\n    participant P as :ProgramaEjecutable\n    participant BD as :BaseDatos\n\n    Usuario-&gt;&gt;F: 1. indicarRegistro(id)\n    F-&gt;&gt;P: 2. buscarRegistro(id)\n    P-&gt;&gt;BD: 3. consultarRegistro(id)\n\n    alt [registro encontrado]\n        BD--&gt;&gt;P: 4. datosRegistro()\n        P--&gt;&gt;F: 5. mostrarRegistro(datos)\n        F--&gt;&gt;Usuario: 6. mostrarFormularioEdicion(datos)\n        Usuario-&gt;&gt;F: 7. modificarCampos(datos)\n        Usuario-&gt;&gt;F: 8. confirmarGrabacion()\n        F-&gt;&gt;P: 9. grabarRegistro(datos)\n        P-&gt;&gt;BD: 10. actualizarRegistro(datos)\n        alt [grabacion correcta]\n            BD--&gt;&gt;P: 11. grabacionOK()\n            P--&gt;&gt;F: 12. confirmacion()\n            F--&gt;&gt;Usuario: 13. mostrarConfirmacion()\n        else [error al grabar]\n            BD--&gt;&gt;P: 11. errorGrabacion()\n            P--&gt;&gt;F: 12. mostrarError(&#39;Error al grabar&#39;)\n            F--&gt;&gt;Usuario: 13. mostrarError(&#39;Error al grabar&#39;)\n        end\n    else [registro no encontrado]\n        BD--&gt;&gt;P: 4. registroNoEncontrado()\n        P--&gt;&gt;F: 5. mostrarError(&#39;Registro no encontrado&#39;)\n        F--&gt;&gt;Usuario: 6. mostrarError(&#39;Registro no encontrado&#39;)\n    end\n&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="bpqTHxUsjjdNOZI-eCtv-140">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry height="1325" width="111" as="geometry" />
          </mxCell>
        </UserObject>
